  double compD0[];
};

layout(binding = 1) buffer compData1 {
  double compD1[];
};

layout(binding = 2) buffer compData2 {
  double compD2[];
};

layout(binding = 3) buffer compData3 {
  double compD3[];
};

layout(binding = 4) buffer compData4 {
  double compD4[];
};

layout(binding = 5) buffer compData5 {
  double compD5[];
};

layout(binding = 6) buffer compData6 {
  double compD6[];
};

