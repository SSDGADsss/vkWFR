  double resultD[];
};

void main() {
  int index = int(gl_WorkGroupID.x) * HANDLE_BLOCK_SIZE + int(gl_LocalInvocationIndex);
  if (index >= DATA_LENGTH) return;
  double maxval = resultD[index];
  maxval = max(maxval, compD0[index]);
  maxval = max(maxval, compD1[index]);
  maxval = max(maxval, compD2[index]);
  maxval = max(maxval, compD3[index]);
  maxval = max(maxval, compD4[index]);
  maxval = max(maxval, compD5[index]);
  maxval = max(maxval, compD6[index]);
  maxval = max(maxval, compD7[index]);
  maxval = max(maxval, compD8[index]);
  maxval = max(maxval, compD9[index]);
  resultD[index] = maxval;
}
